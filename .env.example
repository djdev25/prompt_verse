# OmniVerse AI - Environment Configurations

# General Settings
PROJECT_NAME="OmniVerse AI"
ENVIRONMENT=development  # development, staging, production
DEBUG=true
API_V1_STR=/api/v1

# Security
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=dev_secret_key_change_me_in_production_1234567890
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# CORS Settings (JSON-parsed list of origins)
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "http://localhost:5173"]

# PostgreSQL Configuration
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=omniverse_db
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/omniverse_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# OpenAI & Instructor API Configuration
OPENAI_API_KEY=your-openai-api-key-here
INSTRUCTOR_MODEL=gpt-4o-mini
